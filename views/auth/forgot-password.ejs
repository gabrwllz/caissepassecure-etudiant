<div class="auth-container">
  <div class="card auth-card">
    <% if (typeof token !== 'undefined' && token) { %>
      <h1>Nouveau mot de passe</h1>
      
      <form action="/auth/reset-password" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <input type="hidden" name="token" value="<%= token %>">
        
        <div class="form-group">
          <label for="password" class="form-label">Nouveau mot de passe</label>
          <input type="password" id="password" name="password" class="form-input" required>
        </div>
        
        <div class="form-group">
          <label for="password_confirm" class="form-label">Confirmer le mot de passe</label>
          <input type="password" id="password_confirm" name="password_confirm" class="form-input" required>
        </div>
        
        <button type="submit" class="btn btn-primary btn-block">Réinitialiser</button>
      </form>
    <% } else { %>
      <h1>Mot de passe oublié</h1>
      
      <p class="text-muted mb-3">Entrez votre adresse email pour recevoir un lien de réinitialisation.</p>
      
      <form action="/auth/forgot-password" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="form-group">
          <label for="email" class="form-label">Adresse email</label>
          <input type="email" id="email" name="email" class="form-input" required>
        </div>
        
        <button type="submit" class="btn btn-primary btn-block">Envoyer le lien</button>
      </form>
    <% } %>
    
    <div class="auth-footer">
      <p><a href="/auth/login">Retour à la connexion</a></p>
    </div>
  </div>
</div>
