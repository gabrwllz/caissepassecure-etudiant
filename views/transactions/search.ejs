<h1>Rechercher des transactions</h1>

<div class="card">
  <form action="/transactions/search" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    
    <div class="grid grid-3">
      <div class="form-group">
        <label for="query" class="form-label">Recherche</label>
        <input type="text" id="query" name="query" class="form-input" 
               value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" 
               placeholder="Nom, description...">
      </div>
      
      <div class="form-group">
        <label for="date_from" class="form-label">Date début</label>
        <input type="date" id="date_from" name="date_from" class="form-input"
               value="<%= typeof dateFrom !== 'undefined' ? dateFrom : '' %>">
      </div>
      
      <div class="form-group">
        <label for="date_to" class="form-label">Date fin</label>
        <input type="date" id="date_to" name="date_to" class="form-input"
               value="<%= typeof dateTo !== 'undefined' ? dateTo : '' %>">
      </div>
    </div>
    
    <div class="form-buttons">
      <button type="submit" class="btn btn-primary">Rechercher</button>
      <a href="/transactions/history" class="btn btn-outline">Retour à l'historique</a>
    </div>
  </form>
</div>

<% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
  <p class="mt-3">Résultats pour : <strong><%= searchQuery %></strong></p>
<% } %>

<% if (typeof transactions !== 'undefined' && transactions !== null) { %>
  <div class="card mt-3">
    <% if (transactions.length > 0) { %>
      <div class="table-container">
        <table class="table">
          <thead>
            <tr>
              <th>Date</th>
              <th>De</th>
              <th>Vers</th>
              <th>Description</th>
              <th class="text-right">Montant</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach(function(t) { %>
              <tr>
                <td><%= formatDate(t.created_at) %></td>
                <td><%= t.sender_name || 'Système' %></td>
                <td><%= t.receiver_name %></td>
                <td><%= t.description || '-' %></td>
                <td class="text-right"><%= formatMoney(t.amount) %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="text-muted">Aucune transaction trouvée.</p>
    <% } %>
  </div>
<% } %>
